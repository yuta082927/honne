NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Do NOT expose service role to client: never define NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

SESSION_COOKIE_NAME=ai_uranai_sid
SESSION_COOKIE_SECRET=replace-with-long-random-secret
FREE_USAGE_LIMIT=3

# Temporary debug toggles for /api/fortune troubleshooting
OPENAI_DEBUG=0
FORTUNE_RESPONSE_DEBUG_MARKER=0
FORTUNE_BYPASS_OPENAI=0
NEXT_PUBLIC_OPENAI_DEBUG=0
NEXT_PUBLIC_FORTUNE_DEBUG=0
NEXT_PUBLIC_OPENAI_BYPASS=0
